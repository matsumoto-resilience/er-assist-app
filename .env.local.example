# 使用するLLMプロバイダー。 "claude" または "gemini"。未設定時は claude。
LLM_PROVIDER=claude

# Anthropic APIキー。 https://console.anthropic.com/settings/keys から取得してください。
# LLM_PROVIDER=claude のときに必要です。
ANTHROPIC_API_KEY=

# Gemini APIキー。 https://aistudio.google.com/apikey から取得してください。
# LLM_PROVIDER=gemini のときに必要です。
GEMINI_API_KEY=

# アプリ全体を保護する共通ユーザー名(Basic認証)。
# APP_ACCESS_USERNAME と APP_ACCESS_PASSWORD_HASH の両方が設定されて初めて認証が有効になる。
APP_ACCESS_USERNAME=

# 上記ユーザー名に対応する共通パスワード(Basic認証)のPBKDF2ハッシュ。
# 平文パスワードではなく、必ずハッシュ化した値を設定すること。
# 生成方法: npm run hash-password -- "設定したいパスワード"
# 未設定の場合は認証なしで誰でもアクセスできてしまうため、デプロイ・共有する前には必ず設定すること。
APP_ACCESS_PASSWORD_HASH=
